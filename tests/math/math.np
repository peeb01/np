# 1. 2D Vector Dot Product
print("--- 2D Vector Dot Product ---")
fn dot_product(array v1, array v2) -> int:
    int result = (v1[0] * v2[0]) + (v1[1] * v2[1])
    return result

array vec1 = [2, 3]
array vec2 = [4, 5]
int dp = dot_product(vec1, vec2)
print("Dot product of", vec1, "and", vec2, "is:", dp)


# 2. 2x2 Matrix Multiplication
print("\n--- 2x2 Matrix Multiplication ---")
array A = [[1, 2], [3, 4]]
array B = [[5, 6], [7, 8]]

array C = [[0, 0], [0, 0]]
C[0][0] = (A[0][0] * B[0][0]) + (A[0][1] * B[1][0])
C[0][1] = (A[0][0] * B[0][1]) + (A[0][1] * B[1][1])
C[1][0] = (A[1][0] * B[0][0]) + (A[1][1] * B[1][0])
C[1][1] = (A[1][0] * B[0][1]) + (A[1][1] * B[1][1])

print("Resulting Matrix C:")
print(C[0])
print(C[1])


# 3. Algorithmic Limit Test: Distance Formula
print("\n--- Euclidean Distance Squared ---")
array p1 = [A[0][0], A[1][1]]
array p2 = [B[0][0], B[1][1]]
int dx = p2[0] - p1[0]
int dy = p2[1] - p1[1]
int dist_sq = (dx * dx) + (dy * dy)
print("Squared distance between", p1, "and", p2, "is:", dist_sq)


# 4. Algorithmic Limit Test: Recursion
print("\n--- Recursion Test: Factorial ---")
fn factorial(int n) -> int:
    if n <= 1:
        return 1
    return n * factorial(n - 1)

int fact_result = factorial(5)
print("Factorial of 5 is:", fact_result)

# 5. Benchmark: 1000x1000 Matrix Multiplication Simulation
print("\n--- Benchmark: 1000x1000 Matrix Ops Simulation ---")
print("Executing 1,000,000,000 multiplications (Please wait a second)...")
int multiply_result = 0
for i in range(0, 1000):
    # Reset accumulator for each row to prevent 32-bit int overflow
    multiply_result = 0
    for j in range(0, 1000):
        for k in range(0, 1000):
            # Simulate dot product multiplication of matrix elements
            multiply_result = multiply_result + (j * k)

print("Final row computed result:", multiply_result)

# 6. Visual Dynamic M x N * N x J Matrix Multiplication
print("\n--- Visual M x J Matrix Result ---")
int m = 4
int n = 3
int j_cols = 4
print("Multiplying a 4x3 matrix with a 3x4 matrix...")

array result_matrix[4]
for i in range(0, 4):
    result_matrix[i] = [0, 0, 0, 0]

int cell_value = 0

for r in range(0, m):
    for c in range(0, j_cols):
        cell_value = 0
        for k in range(0, n):
            # Computing matrix cell (r, c)
            cell_value = cell_value + ((r + 1) * (k + 1) + c)
        result_matrix[r][c] = cell_value
    print(result_matrix[r])

# 7. 3D Vector Cross Product
print("\n--- 3D Vector Cross Product ---")
fn cross_product(array a, array b) -> array:
    int cx = (a[1] * b[2]) - (a[2] * b[1])
    int cy = (a[2] * b[0]) - (a[0] * b[2])
    int cz = (a[0] * b[1]) - (a[1] * b[0])
    return [cx, cy, cz]

array vA = [1, 2, 3]
array vB = [4, 5, 6]
array vC = cross_product(vA, vB)
print("Cross product of", vA, "and", vB, "is:", vC)

# 8. True 1000x1000 Matrix Cross Multiplication Benchmark
print("\n--- 8. 1000x1000 True Array Matrix Multiplication ---")
int N_size = 1000
print("Allocating 1000x1000 matrices (A and B)...")

array m_A[1000]
array m_B[1000]
array m_C[1000]

for i in range(0, N_size):
    array r_A[1000]
    array r_B[1000]
    array r_C[1000]
    for j in range(0, N_size):
        r_A[j] = 2
        r_B[j] = 3
        r_C[j] = 0
    m_A[i] = r_A
    m_B[i] = r_B
    m_C[i] = r_C

print("Matrices allocated! Shape of A:", m_A.shape)
print("Computing m_A x m_B (1,000,000,000 Array Operations)...")
print("Please wait, this tests maximum array access speed...")

for i in range(0, N_size):
    for j in range(0, N_size):
        int sum_val = 0
        for k in range(0, N_size):
            sum_val = sum_val + (m_A[i][k] * m_B[k][j])
        m_C[i][j] = sum_val

print("1000x1000 Matrix Multiplication Completed!")
print("Sample Output (m_C[999][999]):", m_C[999][999])
