{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "np",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.np",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.np",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.np",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.np",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.np",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.np",
          "match": "\\b(fn|if|elif|else|for|in|while|return|try|except|throw|import|range)\\b"
        },
        {
          "name": "keyword.operator.logical.np",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.np",
          "match": "\\b(print)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.np",
          "match": "\\b(int|float|string|bool|void|array|dict)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.np",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.np",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.np",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.np",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  ],
  "scopeName": "source.np"
}
